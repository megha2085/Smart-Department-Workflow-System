<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Smart Dashboard</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<style>
body {
    font-family: 'Inter', sans-serif;
    background: linear-gradient(135deg, #4facfe, #00f2fe);
    transition: 0.4s;
}

/* DARK MODE */
body.dark {
    background: #0f172a;
}

/* GLASS EFFECT */
.glass {
    background: rgba(255,255,255,0.15);
    backdrop-filter: blur(15px);
    border-radius: 20px;
    padding: 20px;
    box-shadow: 0 8px 30px rgba(0,0,0,0.2);
}

/* SIDEBAR */
.sidebar {
    width: 240px;
    height: 100vh;
    background: rgba(0,0,0,0.6);
    backdrop-filter: blur(10px);
    color: white;
    position: fixed;
    padding: 20px;
}

/* MAIN */
.main {
    margin-left: 240px;
    padding: 30px;
}

/* CARD ANIMATION */
.card-animate {
    transition: 0.3s;
}
.card-animate:hover {
    transform: scale(1.05);
}

/* BUTTON GLOW */
.btn-glow {
    background: linear-gradient(135deg, #4facfe, #00f2fe);
    border: none;
    color: white;
}
.btn-glow:hover {
    box-shadow: 0 0 15px #4facfe;
}

/* DARK MODE FIX */
body.dark .glass {
    background: rgba(30,41,59,0.8);
    color: white;
}

/* CHART SIZE FIX */
.chart-box {
    width: 300px;
    height: 300px;
    margin: auto;
}
</style>
</head>

<body>

<%
const safeRequests = typeof requests !== 'undefined' ? requests : [];
const pending = safeRequests.filter(r => r.currentStage !== 'Done').length;
const completed = safeRequests.filter(r => r.currentStage === 'Done').length;
%>

<!-- SIDEBAR -->
<div class="sidebar text-center">

    <img src="https://ui-avatars.com/api/?name=<%= user.name %>&background=4facfe&color=fff" 
         class="rounded-circle mb-2" width="80">

    <h5><%= user.name %></h5>
    <p><%= user.role %></p>

    <hr>

    <a href="/dashboard" class="text-white d-block mb-2">Dashboard</a>

    <% if(user.role === 'Mentor'){ %>
    <a href="/notifications/mentor1" class="text-white d-block mb-2">🔔 Notifications</a>
    <% } else if(user.role === 'HOD'){ %>
    <a href="/notifications/hod1" class="text-white d-block mb-2">🔔 Notifications</a>
    <% } else { %>
    <a href="/notifications/<%= user._id %>" class="text-white d-block mb-2">🔔 Notifications</a>
    <% } %>

<a href="/logout" class="text-danger d-block">Logout</a>

    <div class="mt-4">
        <button class="btn btn-glow btn-sm" onclick="toggleDark()">🌙 Dark Mode</button>
    </div>
</div>

<!-- MAIN -->
<div class="main">

<h2 class="text-white mb-4">Welcome, <%= user.name %> 👋</h2>

<!-- STATS -->
<div class="row mb-4">
    <div class="col-md-4">
        <div class="glass card-animate text-center">
            <h6>Total</h6>
            <h2><%= safeRequests.length %></h2>
        </div>
    </div>

    <div class="col-md-4">
        <div class="glass card-animate text-center">
            <h6>Pending</h6>
            <h2><%= pending %></h2>
        </div>
    </div>

    <div class="col-md-4">
        <div class="glass card-animate text-center">
            <h6>Completed</h6>
            <h2><%= completed %></h2>
        </div>
    </div>
</div>

<!-- 📊 CHART -->
<div class="glass mb-4 text-center">
    <h5>Analytics</h5>

    <div class="chart-box">
        <canvas id="chart"></canvas>
    </div>
</div>

<!-- FORM -->
<% if (user.role === 'Student') { %>
<div class="glass mb-4">
    <h5>Create Request</h5>
    <form action="/request/create" method="POST">
        <input type="text" name="title" class="form-control mb-2" placeholder="Title" required>
        <input type="text" name="description" class="form-control mb-2" placeholder="Description" required>
        <button class="btn btn-glow">Submit</button>
    </form>
</div>
<% } %>

<!-- TABLE -->
<div class="glass">
    <h5>Requests</h5>

    <table class="table mt-3 table-striped">
        <thead class="table-dark">
            <tr>
                <th>Title</th>
                <th>Status</th>
                <th>Stage</th>
                <th>Date</th>
                <th>Action</th>
            </tr>
        </thead>

        <tbody>
        <% safeRequests.forEach(req => { %>
        <tr>

            <td><%= req.title %></td>

            <td>
                <% if (req.status.includes('Pending')) { %>
                    <span class="badge bg-warning"><%= req.status %></span>
                <% } else if (req.status === 'Approved') { %>
                    <span class="badge bg-success">Approved</span>
                <% } else { %>
                    <span class="badge bg-danger">Rejected</span>
                <% } %>
            </td>

            <td><%= req.currentStage %></td>
            <td><%= new Date(req.createdAt).toLocaleDateString() %></td>

            <td>
                <% if (
                    (user.role === 'Mentor' && req.currentStage === 'Mentor') ||
                    (user.role === 'HOD' && req.currentStage === 'HOD')
                ) { %>

                <form action="/request/action" method="POST" class="d-flex gap-2">
                    <input type="hidden" name="requestId" value="<%= req._id %>">
                    <button name="action" value="approve" class="btn btn-success btn-sm">✔</button>
                    <button name="action" value="reject" class="btn btn-danger btn-sm">✖</button>
                </form>

                <% } else { %>
                    <span class="text-muted">—</span>
                <% } %>
            </td>

        </tr>
        <% }) %>
        </tbody>
    </table>
</div>

</div>

<script>
// 🌙 DARK MODE (with memory)
function toggleDark() {
    document.body.classList.toggle("dark");
    localStorage.setItem("darkMode", document.body.classList.contains("dark"));
}

if (localStorage.getItem("darkMode") === "true") {
    document.body.classList.add("dark");
}

// 📊 CHART (SMALL SIZE FIXED)
new Chart(document.getElementById('chart'), {
    type: 'doughnut',
    data: {
        labels: ['Pending', 'Completed'],
        datasets: [{
            data: [<%= pending %>, <%= completed %>]
        }]
    },
    options: {
        responsive: true,
        maintainAspectRatio: false
    }
});
</script>

</body>
</html>