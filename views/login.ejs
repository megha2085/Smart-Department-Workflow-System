<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Login</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
    <style>
        body {
            font-family: 'Inter', sans-serif;
            background: #f0f2f5;
            height: 100vh;
            display: flex;
        }
        
        .split-left {
            flex: 1;
            background-image: url('https://images.unsplash.com/photo-1557804506-669a67965ba0?ixlib=rb-4.0.3&auto=format&fit=crop&w=1974&q=80');
            background-size: cover;
            background-position: center;
            position: relative;
        }

        .split-left::after {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0; bottom: 0;
            background: linear-gradient(to right, rgba(0,0,0,0.6), rgba(0,0,0,0.2));
        }

        .left-content {
            position: relative;
            z-index: 10;
            height: 100%;
            display: flex;
            flex-direction: column;
            justify-content: center;
            padding: 60px;
            color: white;
        }

        .split-right {
            width: 500px;
            background: white;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 60px;
        }

        .form-control {
            border: 2px solid #eee;
            border-radius: 12px;
            padding: 14px 20px;
            transition: all 0.3s;
        }
        .form-control:focus {
            border-color: #4facfe;
            box-shadow: 0 0 0 4px rgba(79, 172, 254, 0.1);
        }

        .btn-login {
            background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
            border: none;
            padding: 14px;
            border-radius: 12px;
            font-weight: 700;
            font-size: 1rem;
            color: white;
            letter-spacing: 0.5px;
            transition: transform 0.2s;
        }
        .btn-login:hover { transform: scale(1.02); box-shadow: 0 5px 15px rgba(79, 172, 254, 0.4); }

        .feature-icon {
            width: 50px;
            height: 50px;
            background: rgba(255,255,255,0.1);
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 15px;
            backdrop-filter: blur(5px);
        }
    </style>
</head>
<body>

    <!-- Left Side (Image & Branding) -->
    <div class="split-left">
        <div class="left-content">
            <h1 class="display-5 fw-bold mb-4">Manage Approvals <br>Effortlessly.</h1>
            <p class="lead opacity-75 mb-5">Join the paperless revolution. Track requests in real-time.</p>
            
            <div class="d-flex gap-4">
                <div>
                    <div class="feature-icon"><i class="bi bi-lightning-charge text-white"></i></div>
                    <h5 class="fw-bold">Fast</h5>
                    <p class="small opacity-75">Instant processing</p>
                </div>
                <div>
                    <div class="feature-icon"><i class="bi bi-shield-check text-white"></i></div>
                    <h5 class="fw-bold">Secure</h5>
                    <p class="small opacity-75">Data encrypted</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Right Side (Form) -->
    <div class="split-right">
        <div class="w-100">
            <h2 class="fw-bold mb-2">Welcome Back</h2>
            <p class="text-muted mb-5">Login to your dashboard</p>
            
            <% if (error) { %> 
                <div class="alert alert-danger py-2 border-0 bg-light-danger"><%= error %></div> 
            <% } %>

            <form action="/login" method="POST">
                <div class="mb-4">
                    <label class="form-label small fw-bold text-muted">EMAIL ADDRESS</label>
                    <input type="email" name="email" class="form-control" placeholder="Enter your email" required>
                </div>
                <div class="mb-4">
                    <label class="form-label small fw-bold text-muted">PASSWORD</label>
                    <input type="password" name="password" class="form-control" placeholder="Enter password" required>
                </div>
                <button type="submit" class="btn btn-login w-100 mt-2">Login to Dashboard</button>
            </form>
            
            <div class="text-center mt-5">
                <p class="text-muted">Don't have an account? <a href="/register" class="fw-bold text-decoration-none">Create One</a></p>
            </div>
        </div>
    </div>
</body>
</html>