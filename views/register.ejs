<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Register</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; height: 100vh; display: flex; }
        .split-left {
            width: 500px;
            background: white;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 60px;
        }
        .split-right {
            flex: 1;
            background-image: url('https://images.unsplash.com/photo-1531545514256-b1400bc00f31?ixlib=rb-4.0.3&auto=format&fit=crop&w=1974&q=80');
            background-size: cover;
            background-position: center;
            position: relative;
        }
        .split-right::after {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0; bottom: 0;
            background: linear-gradient(to left, rgba(0,0,0,0.7), rgba(0,0,0,0.2));
        }
        .form-control {
            border: 2px solid #eee;
            border-radius: 12px;
            padding: 14px 20px;
        }
        .form-control:focus { border-color: #00f2fe; box-shadow: 0 0 0 4px rgba(0, 242, 254, 0.1); }
        .btn-register {
            background: linear-gradient(135deg, #000000 0%, #434343 100%);
            border: none;
            padding: 14px;
            border-radius: 12px;
            font-weight: 700;
            color: white;
            width: 100%;
        }
        .btn-register:hover { transform: scale(1.01); }
    </style>
</head>
<body>

    <!-- Left Side (Form) -->
    <div class="split-left">
        <div class="w-100">
            <h2 class="fw-bold mb-2">Create Account</h2>
            <p class="text-muted mb-4">Join the workflow network</p>
            
            <% if (error) { %> <div class="alert alert-danger py-2"><%= error %></div> <% } %>

            <form action="/register" method="POST">
                <div class="mb-3">
                    <input type="text" name="name" class="form-control" placeholder="Full Name" required>
                </div>
                <div class="mb-3">
                    <input type="email" name="email" class="form-control" placeholder="Email Address" required>
                </div>
                <div class="mb-3">
                    <input type="password" name="password" class="form-control" placeholder="Password" required>
                </div>
                <div class="mb-4">
                    <select name="role" class="form-control">
                        <option value="Student">Student</option>
                        <option value="Mentor">Mentor (Approver)</option>
                        <option value="HOD">HOD (Admin)</option>
                    </select>
                </div>
                <button type="submit" class="btn btn-register">Register</button>
            </form>
            <p class="text-center mt-4 text-muted">
                Already a member? <a href="/login" class="fw-bold text-dark">Login</a>
            </p>
        </div>
    </div>

    <!-- Right Side (Image) -->
    <div class="split-right"></div>

</body>
</html>