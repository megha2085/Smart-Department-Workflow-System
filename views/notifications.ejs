<!DOCTYPE html>
<html>
<head>
  <title>Notifications</title>
  <style>
    body{
      font-family: Arial;
      padding:20px;
      background:#f5f5f5;
    }
    .box{
      background:white;
      padding:15px;
      margin-bottom:10px;
      border-radius:8px;
      box-shadow:0 2px 5px rgba(0,0,0,0.1);
    }
    small{
      color:gray;
    }
  </style>
</head>
<body>

<h2>Notifications</h2>

<% if(notifications.length === 0){ %>
  <p>No notifications yet.</p>
<% } %>

<% notifications.forEach(n => { %>
  <div class="box">
    <p><%= n.message %></p>
    <small><%= n.createdAt.toLocaleString() %></small>
  </div>
<% }) %>

</body>
</html>